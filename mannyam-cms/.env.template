# ============================================================================
# MANNYAM Studio CMS — Complete Environment Variables Template
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# ============================================================================

# ─── SUPABASE ───────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# The JWT secret from your VPS Docker Compose .env (used for token verification)
JWT_SECRET=

# ─── SITE ─────────────────────────────────────────────────────────────────────
# The public-facing domain. Used for canonical URLs, sitemaps, OG tags.
NEXT_PUBLIC_SITE_URL=

# ─── CRON & REVALIDATION ─────────────────────────────────────────────────────
# Secret for the /api/cron/publish-scheduled endpoint
CRON_SECRET=

# Secret for on-demand ISR revalidation
REVALIDATE_SECRET=

# ─── GOOGLE SEARCH CONSOLE ──────────────────
# Service account email from your Google Cloud project
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Service account private key (replace literal newlines with \n, wrap in quotes)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# The Search Console property URL (must match the verified property)
GSC_SITE_URL=

# ─── EMAIL NOTIFICATIONS (Resend) ───────────────────────────────────
RESEND_API_KEY=
ADMIN_EMAIL=

# ─── RAZORPAY PAYMENTS ─────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# ============================================================================
# NOTES:
# - On the VPS, this file must be at the SAME directory level as package.json
# - NEVER expose SUPABASE_SERVICE_ROLE_KEY or RAZORPAY_KEY_SECRET to the browser
# ============================================================================
