# ============================================================================
# MANNYAM Studio CMS — Complete Environment Variables Template
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# ============================================================================

# ─── SUPABASE (Self-hosted on Hostinger VPS via Docker Compose) ───────────────
# Dev: use Cloudflare Quick Tunnel URL or SSH tunnel (localhost:7777)
# Production: use your Caddy-proxied domain (e.g. https://api.mannyam.in)
NEXT_PUBLIC_SUPABASE_URL=https://your-cloudflare-tunnel-or-caddy-domain.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key...

# The JWT secret from your VPS Docker Compose .env (used for token verification)
JWT_SECRET=your-jwt-secret-from-vps-env-file

# ─── SITE ─────────────────────────────────────────────────────────────────────
# The public-facing domain. Used for canonical URLs, sitemaps, OG tags.
NEXT_PUBLIC_SITE_URL=https://mannyam.in

# ─── CRON & REVALIDATION ─────────────────────────────────────────────────────
# Secret for the /api/cron/publish-scheduled endpoint (Step 2)
CRON_SECRET=your-random-cron-secret

# Secret for on-demand ISR revalidation (Steps 11-12)
REVALIDATE_SECRET=your-random-revalidation-secret

# ─── GOOGLE SEARCH CONSOLE (Step 8 — after Manual Step 8-A) ──────────────────
# Service account email from your Google Cloud project
GOOGLE_SERVICE_ACCOUNT_EMAIL=mannyam-cms-service@your-project.iam.gserviceaccount.com

# Service account private key (replace literal newlines with \n, wrap in quotes)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# The Search Console property URL (must match the verified property)
GSC_SITE_URL=https://mannyam.in

# ─── EMAIL NOTIFICATIONS (Step 9 — Resend) ───────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
ADMIN_EMAIL=admin@mannyam.in

# ─── RAZORPAY PAYMENTS (Step 15 — Test mode first, then live) ─────────────────
# Test keys: get from Razorpay Dashboard > Settings > API Keys (Test Mode)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ============================================================================
# NOTES:
# - On the VPS, this file must be at the SAME directory level as package.json
# - If you see "supabaseUrl is required" during build, the file is missing or
#   in the wrong directory
# - For production, swap rzp_test_ keys with rzp_live_ keys after KYC approval
# - NEVER expose SUPABASE_SERVICE_ROLE_KEY or RAZORPAY_KEY_SECRET to the browser
# ============================================================================
